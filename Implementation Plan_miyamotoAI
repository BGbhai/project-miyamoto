function AIWorkoutDecisionCard({ state, dispatch }) {
  const decision = state.planState.aiWorkoutDecision;
  const status = state.planState.aiWorkoutDecisionStatus;
  const enabled = state.aiConfig.enabled && state.aiConfig.apiKey;
  const adjPending = state.planState.aiWorkoutAdjPending;

  const generate = async () => {
    if (!enabled) return;
    dispatch({ type: 'SET_AI_WORKOUT_STATUS', payload: 'loading' });
    try {
      const d = await callAIWorkoutDecision(state);
      dispatch({ type: 'SET_AI_WORKOUT_DECISION', payload: { decision: d } });
    } catch (err) {
      dispatch({ type: 'SET_AI_WORKOUT_DECISION', payload: { decision: null, error: err.message } });
    }
  };

  // Auto-generate on mount if not already fresh (within 4 hours)
  useEffect(() => {
    if (!enabled || status === 'loading' || status === 'ready') return;
    const genAt = state.planState.aiWorkoutDecisionGeneratedAt;
    const fresh = genAt && (Date.now() - new Date(genAt).getTime()) < 4 * 3600 * 1000;
    if (fresh) return;
    generate();
  }, []); // eslint-disable-line

  if (!enabled) return null;

  return (
    <div className="border border-red-900 bg-neutral-950 p-5 space-y-3">
      <div className="flex items-center justify-between">
        <div className="text-red-500 font-mono text-xs uppercase tracking-widest">TODAY'S AI PLAN</div>
        <button onClick={generate} disabled={status === 'loading'}
          className="border border-neutral-700 px-3 py-1 font-mono text-xs text-neutral-400 uppercase disabled:opacity-40 active:bg-neutral-900"
          style={{ WebkitTapHighlightColor: 'transparent' }}>
          {status === 'loading' ? 'PLANNING...' : 'REFRESH'}
        </button>
      </div>

      {status === 'loading' && (
        <div className="text-neutral-500 font-mono text-xs">AI is reviewing your data and building today's session...</div>
      )}
      {status === 'error' && (
        <div className="space-y-2">
          <div className="text-red-400 font-mono text-xs">{state.planState.aiWorkoutDecisionError}</div>
          <button onClick={generate} className="border border-neutral-700 px-3 py-2 font-mono text-xs text-neutral-400 uppercase">RETRY</button>
        </div>
      )}
      {status === 'ready' && decision && (
        <div className="space-y-3">
          <div>
            <div className="text-neutral-200 font-mono text-sm font-bold uppercase">{decision.sessionType}{decision.maSubtype ? ` — ${decision.maSubtype}` : ''}</div>
            <div className="text-neutral-400 font-mono text-xs mt-1">{decision.sessionFocus}</div>
          </div>
          <div className="border-l-2 border-yellow-500 pl-3 text-neutral-300 font-mono text-xs">{decision.rationale}</div>
          {decision.watchOut && (
            <div className="border-l-2 border-red-700 pl-3 text-red-400 font-mono text-xs">⚠ {decision.watchOut}</div>
          )}
          <div className="space-y-1">
            <div className="text-neutral-500 font-mono text-xs uppercase">Planned exercises ({decision.exercises.length}):</div>
            {decision.exercises.map((ex, i) => (
              <div key={i} className="font-mono text-xs text-neutral-300">
                {i+1}. {ex.name} — {ex.sets}×{ex.reps} RPE{ex.rpe}
                {ex.aiNote && <div className="text-neutral-600 pl-4">{ex.aiNote}</div>}
              </div>
            ))}
          </div>
          {adjPending && <div className="text-yellow-400 font-mono text-xs">AI is adjusting plan based on your message...</div>}
          <button
            onClick={() => {
              dispatch({
                type: 'START_SESSION_FROM_PLAN',
                payload: {
                  type: decision.sessionType,
                  source: 'ai_decision',
                  timeAvailable: decision.timeEstimateMinutes || 60,
                  maSessionSubtype: decision.maSubtype || 'technical',
                  plannerSource: 'ai',
                },
              });
              dispatch({ type: 'SET_VIEW', payload: 'train' });
            }}
            className="w-full bg-red-500 text-neutral-950 py-4 font-mono font-bold text-sm uppercase tracking-widest active:bg-red-700"
