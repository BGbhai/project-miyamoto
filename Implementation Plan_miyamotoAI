#### 1e. New `AIChatPanel` component (add before `HomeView`):

```jsx
function AIChatPanel({ state, dispatch }) {
  const [input, setInput] = useState('');
  const bottomRef = useRef(null);
  const history = state.planState.chatHistory || [];
  const loading = state.planState.chatLoading;

  useEffect(() => {
    bottomRef.current?.scrollIntoView({ behavior: 'smooth' });
  }, [history.length, loading]);

  const send = async () => {
    const text = input.trim();
    if (!text || loading) return;
    setInput('');
    if (!state.aiConfig.enabled || !state.aiConfig.apiKey) {
      dispatch({ type: 'APPEND_CHAT_MESSAGE', payload: { role: 'coach', text: 'Enable AI coach and add your Gemini API key in Settings → AI to use this feature.' } });
      return;
    }
    dispatch({ type: 'APPEND_CHAT_MESSAGE', payload: { role: 'user', text } });
    try {
      const reply = await callGeminiChat(state, text);
      dispatch({ type: 'APPEND_CHAT_MESSAGE', payload: { role: 'coach', text: reply } });
    } catch (err) {
      dispatch({ type: 'APPEND_CHAT_MESSAGE', payload: { role: 'coach', text: `Error: ${err.message}` } });
    }
  };

  return (
    <div className="border border-neutral-800 space-y-0">
      <div className="flex items-center justify-between px-4 pt-4 pb-2">
        <div className="text-red-500 font-mono text-xs uppercase tracking-widest">COACH CHAT</div>
        {history.length > 0 && (
          <button onClick={() => dispatch({ type: 'CLEAR_CHAT_HISTORY' })}
            className="text-neutral-600 font-mono text-xs uppercase hover:text-neutral-400">
            CLEAR
          </button>
        )}
      </div>

      {/* Message thread */}
      <div className="px-4 space-y-3 overflow-y-auto" style={{ maxHeight: 320, minHeight: 80 }}>
        {history.length === 0 && (
          <div className="text-neutral-600 font-mono text-xs py-4 text-center">
            Ask about today's plan, how to modify it, nutrition, recovery — anything.
          </div>
        )}
        {history.map((msg, i) => (
          <div key={i} className={`flex ${msg.role === 'user' ? 'justify-end' : 'justify-start'}`}>
            <div className={`max-w-[85%] px-3 py-2 font-mono text-xs whitespace-pre-wrap leading-relaxed ${
              msg.role === 'user'
                ? 'bg-red-500 text-neutral-950'
                : 'border border-neutral-700 text-neutral-200'
            }`}>
              {msg.text}
            </div>
          </div>
        ))}
        {loading && (
          <div className="flex justify-start">
            <div className="border border-neutral-700 px-3 py-2 font-mono text-xs text-neutral-500">
              Coach is thinking...
            </div>
          </div>
        )}
        <div ref={bottomRef} />
      </div>

      {/* Input row */}
      <div className="flex gap-0 border-t border-neutral-800 mt-2">
        <input
          value={input}
          onChange={e => setInput(e.target.value)}
          onKeyDown={e => { if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); send(); } }}
          placeholder="Message your coach..."
          className="flex-1 bg-neutral-900 px-4 py-3 font-mono text-sm text-neutral-100 placeholder-neutral-700 outline-none"
        />
        <button onClick={send} disabled={loading || !input.trim()}
          className="px-5 bg-red-500 text-neutral-950 font-mono text-xs font-bold uppercase disabled:opacity-40 active:bg-red-700"
          style={{ WebkitTapHighlightColor: 'transparent' }}>
          SEND
        </button>
      </div>
    </div>
  );
}
```

