  const p = state.profile;
  const r = state.readiness;
  const d = state.domains;
  const memory = state.planState.aiMemory || {};
  const recentLogs = (state.sessionLogs || []).slice(-7).map(l =>
    `${new Date(l.timestamp).toLocaleDateString()}: ${l.type}${l.maSubtype ? `(${l.maSubtype})` : ''} RPE=${l.rpe} recovery=${l.recovery}`
  ).join('\n') || 'No recent sessions.';
  const muscleAdvice = getMuscleRecoveryAdvice(state.muscleRecovery);
  const fatigued = muscleAdvice.fatiguedMuscles.join(', ') || 'none';
  const recovering = muscleAdvice.recoveringMuscles.join(', ') || 'none';
  const injuries = Object.entries(state.constraints?.injuries || {}).filter(([,v]) => v).map(([k]) => k).join(', ') || 'none';
  const today = new Date().toLocaleDateString('en-GB', { weekday: 'long' });
  const timeAvailable = state.profile.timeByDay?.[today.slice(0,3).toLowerCase()] || state.programConfig.defaultSessionMinutes || 60;
  const sessionTypes = Object.keys(state.planState.scheduledSlotsByDate?.[new Date().toISOString().slice(0,10)] || {}).join(', ') || 'none scheduled';

  const prompt = `You are an expert performance coach programming a training session for ${p.name || 'an athlete'}.

ATHLETE PROFILE:
- Goal: ${p.primaryGoal || 'complete athlete'} | Secondary: ${(p.secondaryGoals || []).join(', ') || 'none'}
- Training age: ${p.trainingAge} | Block: ${p.currentBlock} | Block week: ${p.blockWeek || 1}
- Age: ${p.age || '?'} | Bodyweight: ${p.bodyweight || '?'}kg
- Timeline: ${p.timelineWeeks || 12} weeks

STRENGTH PRs: squat=${p.skillAssessments.squatRM}kg, bench=${p.skillAssessments.benchRM}kg, deadlift=${p.skillAssessments.deadliftRM}kg
SKILL ASSESSMENTS: max pull-ups=${p.skillAssessments.maxPullUps}, max push-ups=${p.skillAssessments.maxPushUps}, handstand=${p.skillAssessments.handstandHold}s
DOMAIN LEVELS: strength=${d?.strength?.level || 1}, conditioning=${d?.conditioning?.level || 1}, mobility=${d?.mobility?.level || 1}

TODAY:
- Day: ${today} | Time available: ${timeAvailable} min
- Readiness score: ${r.score}/100 (${r.band}) | Sleep: ${r.inputs.sleep}/10 | Stress: ${r.inputs.stress}/10

MUSCLE RECOVERY:
- Fatigued (do not load directly): ${fatigued}
- Recovering (light only): ${recovering}
- Active injuries: ${injuries}

RECENT SESSIONS (last 7):
${recentLogs}

AI MEMORY (Atomic Facts):
${JSON.stringify(memory.facts || [])}

AVAILABLE SESSION TYPES: gym, martialArts (striking|grappling), running, mobility

INSTRUCTIONS:
1. Pick the best session type and (if martialArts) subtype for today.
2. Select 4-7 specific exercises appropriate for the block, readiness, and muscle state.
3. For each exercise include: name, sets, reps (or duration), target RPE, and a 1-sentence aiNote specific to this athlete.
4. Provide a sessionFocus, watchOut, and rationale.
5. Return ONLY valid JSON matching this exact schema — no markdown, no preamble:

{
  "sessionType": "gym",
  "maSubtype": null,
  "rationale": "...",
  "sessionFocus": "...",
  "watchOut": "...",
  "timeEstimateMinutes": 55,
  "exercises": [
    { "name": "Back Squat", "sets": 4, "reps": "5", "rpe": 8, "aiNote": "..." }
  ]
}`;

  const body = {
    contents: [{ parts: [{ text: prompt }] }],
    generationConfig: {
      temperature: 0.3,
      maxOutputTokens: 1200,
      responseMimeType: 'application/json',
    },
  };

  const data = await callGeminiWithRetry({
    apiKey, endpoint, body, requestType: 'AI workout decision',
    timeoutMs: AI_PLAN_REQUEST_TIMEOUT_MS,
    retryDelaysMs: AI_PLAN_RETRY_DELAYS_MS,
    maxRetryAfterMs: AI_PLAN_MAX_RETRY_AFTER_MS,
  });
  const text = sanitizeGeminiText(extractGeminiText(data));
  const parsed = parseGeminiJson(text, 'workout decision');

  // Validate
  if (!parsed.sessionType || !Array.isArray(parsed.exercises) || parsed.exercises.length === 0) {
    throw new Error('AI returned an invalid workout structure.');
