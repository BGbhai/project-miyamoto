async function callGeminiChat(state, userMessage) {
  const { apiKey, endpoint } = state.aiConfig;
  const history = (state.planState.chatHistory || []).slice(-10); // rolling 10 msgs

  // Build conversation turns for Gemini
  const turns = history.map(m => ({
    role: m.role === 'user' ? 'user' : 'model',
    parts: [{ text: m.text }],
  }));

  // System context injected as first model turn
  const systemContext = buildChatSystemContext(state);
  const systemTurn = { role: 'model', parts: [{ text: systemContext }] };

  const body = {
    contents: [systemTurn, ...turns, { role: 'user', parts: [{ text: userMessage }] }],
    generationConfig: { temperature: 0.7, maxOutputTokens: 512 },
  };

  const data = await callGeminiWithRetry({ apiKey, endpoint, body, requestType: 'Coach chat' });
  const text = sanitizeGeminiText(extractGeminiText(data));
  if (!text) throw new Error('Empty response from coach.');
  return text;
}

function buildChatSystemContext(state) {
  const p = state.profile;
  const r = state.readiness;
  const d = state.domains;
  const today = new Date().toLocaleDateString('en-GB', { weekday: 'long', day: 'numeric', month: 'short' });
  const recentTypes = (state.sessionLogs || []).slice(-5).map(l => `${l.type}(RPE${l.rpe})`).join(', ') || 'none';
  const muscleAdvice = getMuscleRecoveryAdvice(state.muscleRecovery);
  const fatigued = muscleAdvice.fatiguedMuscles.join(', ') || 'none';
  const injuries = Object.entries(state.constraints?.injuries || {}).filter(([,v]) => v).map(([k]) => k).join(', ') || 'none';

  return `You are a strict but supportive personal coach for ${p.name || 'the athlete'}.
Today: ${today}. Readiness: ${r.score}/100 (${r.band}). Sleep: ${r.inputs.sleep}/10. Stress: ${r.inputs.stress}/10.
Goal: ${p.primaryGoal || 'complete athlete'} (Secondary: ${(p.secondaryGoals || []).join(', ') || 'none'}). Block: ${p.currentBlock}. Training age: ${p.trainingAge}.
Strength PRs: squat=${p.skillAssessments.squatRM}kg, bench=${p.skillAssessments.benchRM}kg, deadlift=${p.skillAssessments.deadliftRM}kg
Domain Levels: strength=${d?.strength?.level || 1}, conditioning=${d?.conditioning?.level || 1}, mobility=${d?.mobility?.level || 1}
Recent sessions: ${recentTypes}. Fatigued muscles: ${fatigued}. Active injuries: ${injuries}.
Today's AI plan: ${state.planState.primaryRecommendation?.type || 'not yet generated'} — ${state.planState.reasonText || ''}.
AI memory facts: ${JSON.stringify(state.planState.aiMemory?.facts || [])}.
Respond concisely and practically. You may suggest adjusting today's workout if the athlete describes changes in how they feel.`;
