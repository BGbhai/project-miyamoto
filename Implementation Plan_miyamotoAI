#### `callAIPostSessionMemoryUpdate(state, sessionLog)` — update AI memory after a session:

```js
async function callAIPostSessionMemoryUpdate(state, sessionLog) {
  const { apiKey, endpoint } = state.aiConfig;
  const memory = state.planState.aiMemory || {};
  const exercises = (sessionLog.exercises || [])
    .map(ex => `${ex.name}: ${ex.result?.performed?.setsCompleted || '?'} sets, RPE ${ex.result?.performed?.effortRPE || '?'}${ex.result?.performed?.pain ? ' ⚠ PAIN' : ''}`)
    .join('\n') || 'No exercise details.';

  const prompt = `Update the coach memory for ${state.profile.name || 'athlete'} after this session.

SESSION COMPLETED:
Type: ${sessionLog.type}. Overall RPE: ${sessionLog.rpe}. Recovery rating: ${sessionLog.recovery}.
Notes from athlete: "${sessionLog.notes || 'none'}".
Exercises:
${exercises}

CURRENT MEMORY (Atomic Facts):
${JSON.stringify(memory.facts || [])}

INSTRUCTIONS:
You maintain the AI memory as an array of atomic facts. 
Based on the new session, return a diff of the facts to maintain an accurate, up-to-date fact store. 
Categories: 'injury', 'progression', 'pattern', 'preference'.

Return ONLY valid JSON matching this schema:
{
  "add": [{ "id": "unique_str", "category": "...", "fact": "...", "date": "ISO date", "confidence": 0.9 }],
  "update": [{ "id": "existing_id", "fact": "updated text...", "confidence": 0.95 }],
  "delete": ["id_to_remove"]
}`;

  const body = {
    contents: [{ parts: [{ text: prompt }] }],
    generationConfig: { temperature: 0.2, maxOutputTokens: 600, responseMimeType: 'application/json' },
  };
  const data = await callGeminiWithRetry({ apiKey, endpoint, body, requestType: 'Memory update' });
  const text = sanitizeGeminiText(extractGeminiText(data));
  const diff = parseGeminiJson(text, 'memory update');
  
  // Process the diff
  let facts = [...(memory.facts || [])];
  if (Array.isArray(diff.delete)) {
    facts = facts.filter(f => !diff.delete.includes(f.id));
  }
  if (Array.isArray(diff.update)) {
    diff.update.forEach(u => {
      const idx = facts.findIndex(f => f.id === u.id);
      if (idx !== -1) facts[idx] = { ...facts[idx], ...u, date: new Date().toISOString() };
    });
  }
  if (Array.isArray(diff.add)) {
    facts = [...facts, ...diff.add];
  }
  
  return { facts, lastUpdatedAt: new Date().toISOString() };
}
```

