#### 3a. New helper function (add near other helper functions, ~line 2700):

```js
function buildHeatmapData(sessionLogs) {
  // Returns Map<'YYYY-MM-DD', number> for the last 365 days
  const map = new Map();
  const today = new Date();
  for (let i = 364; i >= 0; i--) {
    const d = new Date(today);
    d.setDate(today.getDate() - i);
    const key = d.toISOString().slice(0, 10);
    map.set(key, 0);
  }
  for (const log of sessionLogs || []) {
    const key = new Date(log.timestamp).toISOString().slice(0, 10);
    if (map.has(key)) map.set(key, map.get(key) + 1);
  }
  return map;
}
```

#### 3b. New `SessionHeatmap` component (add before `ProgressView`):

```jsx
const HEATMAP_MONTH_LABELS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const HEATMAP_DAY_LABELS = ['S','M','T','W','T','F','S'];

function SessionHeatmap({ sessionLogs }) {
  const data = useMemo(() => buildHeatmapData(sessionLogs), [sessionLogs]);
  const entries = [...data.entries()]; // Array of ['YYYY-MM-DD', count]

  // Group into weeks (columns of 7)
  const weeks = [];
  let week = [];
  // Pad start so index 0 = Sunday
  const firstDay = new Date(entries[0][0]).getDay(); // 0=Sun
  for (let p = 0; p < firstDay; p++) week.push(null);
  for (const [dateStr, count] of entries) {
    week.push({ dateStr, count });
    if (week.length === 7) { weeks.push(week); week = []; }
  }
  if (week.length) weeks.push(week);

  const cellColor = (count) => {
    if (!count) return '#1a1a1a';
    if (count === 1) return 'rgba(239,68,68,0.5)';
    return '#ef4444';
  };

  // Find month label positions
  const monthLabels = [];
  let lastMonth = -1;
  weeks.forEach((w, wi) => {
    const first = w.find(Boolean);
    if (first) {
      const m = new Date(first.dateStr).getMonth();
      if (m !== lastMonth) { monthLabels.push({ wi, label: HEATMAP_MONTH_LABELS[m] }); lastMonth = m; }
    }
  });

  return (
    <div className="border border-neutral-800 p-4 space-y-2 overflow-x-auto">
      <div className="text-red-500 font-mono text-xs uppercase tracking-widest mb-2">ACTIVITY — LAST 12 MONTHS</div>
      <div style={{ display: 'flex', gap: 2, position: 'relative' }}>
        {/* Day labels */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 2, marginRight: 4 }}>
          {HEATMAP_DAY_LABELS.map((d, i) => (
            <div key={i} style={{ height: 11, fontSize: 9, color: '#525252', fontFamily: 'monospace', lineHeight: '11px' }}>
              {i % 2 === 1 ? d : ''}
            </div>
          ))}
        </div>
        {/* Grid */}
        <div style={{ display: 'flex', flexDirection: 'column', gap: 0 }}>
          {/* Month labels */}
          <div style={{ display: 'flex', gap: 2, marginBottom: 2 }}>
            {weeks.map((_, wi) => {
              const ml = monthLabels.find(m => m.wi === wi);
              return (
                <div key={wi} style={{ width: 11, fontSize: 9, color: '#525252', fontFamily: 'monospace', overflow: 'hidden', whiteSpace: 'nowrap' }}>
                  {ml ? ml.label : ''}
                </div>
              );
            })}
          </div>
          {/* Cells: render 7 rows × N weeks */}
          {[0,1,2,3,4,5,6].map(dayIdx => (
            <div key={dayIdx} style={{ display: 'flex', gap: 2, marginBottom: 2 }}>
              {weeks.map((week, wi) => {
                const cell = week[dayIdx];
                if (!cell) return <div key={wi} style={{ width: 11, height: 11 }} />;
                return (
                  <div key={wi}
                    title={`${cell.dateStr}: ${cell.count} session${cell.count !== 1 ? 's' : ''}`}
                    style={{ width: 11, height: 11, background: cellColor(cell.count), borderRadius: 2 }}
                  />
                );
              })}
            </div>
          ))}
        </div>
      </div>
      <div className="flex gap-4 font-mono text-xs text-neutral-600 mt-1">
        <span>■ <span style={{color:'#1a1a1a',border:'1px solid #333',display:'inline-block',width:8}}></span> None</span>
        <span>■ <span style={{color:'rgba(239,68,68,0.5)'}}>■</span> 1 session</span>
        <span>■ <span style={{color:'#ef4444'}}>■</span> 2+ sessions</span>
      </div>
    </div>
  );
}
